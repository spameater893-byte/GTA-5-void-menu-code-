#include "script.h"
#include <string>
#include <cmath>

// ==========================================
// 1. GLOBAL TOGGLE TRACKING VARIABLES
// ==========================================
bool initialized = false;
int splashTimer = 240; // 4-second splash screen check at 60fps

// Weapon Toggles
bool tenfoldBullets = false;
bool hundredfoldBullets = false;
bool infAmmo = false;
bool noReload = false;
bool ultimateSpeedShoot = false;
bool speedyRpg = false;

// Player Toggles
bool godmode = false;
bool moneyDrop = false;
bool noMissionFailure = false;

// Vehicle Spawn Name Matrix
std::string vehicleInputName = "";

// ==========================================
// 2. HELPER REVERSE ENGINEERING COMMANDS
// ==========================================
void KeyboardInputHelper() {
    MISC::DISPLAY_ONSCREEN_KEYBOARD(1, "FMMC_KEY_TIP8", "", "", "", "", "", 32);
    while (MISC::UPDATE_ONSCREEN_KEYBOARD() == 0) {
        scriptWait(0); 
    }
    if (MISC::UPDATE_ONSCREEN_KEYBOARD() == 1) {
        vehicleInputName = MISC::GET_ONSCREEN_KEYBOARD_RESULT();
    }
}

void DrawMenuText(const char* text, int font, float x, float y, float scaleX, float scaleY, int r, int g, int b, int a, bool center) {
    HUD::BEGIN_TEXT_COMMAND_DISPLAY_TEXT("STRING");
    HUD::ADD_TEXT_COMPONENT_SUBSTRING_PLAYER_NAME(text);
    HUD::SET_TEXT_FONT(font);
    HUD::SET_TEXT_SCALE(scaleX, scaleY);
    HUD::SET_TEXT_COLOUR(r, g, b, a);
    if (center) HUD::SET_TEXT_CENTRE(true);
    HUD::END_TEXT_COMMAND_DISPLAY_TEXT(x, y, 0);
}

// ==========================================
// 3. THE ERROR-FREE UI AND HEARTBEAT LOOP
// ==========================================
void MenuExample::scriptTick() {
    
    // --- FEATURE A: THE CUSTOM TIKTOK SPLASH SCREEN ---
    if (splashTimer > 0) {
        splashTimer--;
        
        // Deep space dark dark void canvas background
        GRAPHICS::DRAW_RECT(0.5f, 0.5f, 1.0f, 1.0f, 10, 5, 20, 255, false);
        
        // Upper neon boundary lines
        GRAPHICS::DRAW_RECT(0.5f, 0.05f, 1.0f, 0.01f, 147, 51, 234, 200, false); 
        GRAPHICS::DRAW_RECT(0.5f, 0.95f, 1.0f, 0.01f, 88, 28, 135, 200, false);  

        int alphaPulse = (int)(155 + (100 * sin(splashTimer * 0.05f)));

        DrawMenuText("WELCOME TO VOID MENU", 1, 0.5f, 0.40f, 1.2f, 1.2f, 168, 85, 247, alphaPulse, true);
        DrawMenuText("made by ccgvr1 on TikTok", 4, 0.5f, 0.52f, 0.6f, 0.6f, 255, 255, 255, 230, true);
        DrawMenuText("Loading system files...", 0, 0.5f, 0.85f, 0.35f, 0.35f, 156, 163, 175, 150, true);

        return; 
    }

    // --- FEATURE B: CUSTOM SPACE PURPLE CORE THEMEING ---
    if (!initialized) {
        // Structural theme assignments configured natively
        this->SetHeaderColor(48, 15, 71, 240);       
        this->SetSubheaderColor(26, 10, 41, 245);    
        this->SetBackgroundColor(15, 6, 26, 220);     
        this->SetHighlightColor(168, 85, 247, 255);  
        this->SetTextColor(243, 232, 255, 255);      
        initialized = true;
    }

    // --- FEATURE C: DIRECTORY ROUTING AND MENUS ---
    if (this->CurrentMenu() == "mainmenu") {
        this->Title("Void Menu");
        if (this->MenuOption("Player Options", "playersub")) {}
        if (this->MenuOption("Weapon Options", "weaponsub")) {}
        if (this->MenuOption("Vehicle Spawner", "vehiclesub")) {}
    }

    // --- PLAYER DIRECTORY ---
    if (this->CurrentMenu() == "playersub") {
        this->Title("Player Options");
        if (this->BoolOption("God Mode", &godmode)) {}
        if (this->BoolOption("Money Drop", &moneyDrop)) {}
        if (this->BoolOption("No Mission Failure", &noMissionFailure)) {}
    }

    // --- WEAPON DIRECTORY ---
    if (this->CurrentMenu() == "weaponsub") {
        this->Title("Weapon Options");
        
        if (this->BoolOption("Tenfold Bullets (x10)", &tenfoldBullets)) {}
        if (this->BoolOption("Hundredfold Bullets (x100)", &hundredfoldBullets)) {}
        if (this->BoolOption("Infinite Ammo", &infAmmo)) {}
        if (this->BoolOption("No Reloading", &noReload)) {}
        if (this->BoolOption("Ultimate Speed Shoot", &ultimateSpeedShoot)) {}
        if (this->BoolOption("Speedy RPG", &speedyRpg)) {}
        
        if (this->Button("Give All Weapons")) {
            Ped playerPed = PLAYER::PLAYER_PED_ID();
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_PISTOL"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_CARBINERIFLE"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_SPECIALCARBINE"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_MICROSMG"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_PUMPSHOTGUN"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_RPG"), 9999, true);
            WEAPON::GIVE_DELAYED_WEAPON_TO_PED(playerPed, MISC::GET_HASH_KEY("WEAPON_HOMINGLAUNCHER"), 9999, true);
        }
        if (this->Button("Remove All Weapons")) {
            WEAPON::REMOVE_ALL_PED_WEAPONS(PLAYER::PLAYER_PED_ID(), true);
        }
    }

    // --- VEHICLE SPAWNER DIRECTORY ---
    if (this->CurrentMenu() == "vehiclesub") {
        this->Title("Vehicle Spawner");
        
        if (this->Button("Type Vehicle Name to Spawn")) {
            KeyboardInputHelper(); 
            
            if (!vehicleInputName.empty()) {
                Hash modelHash = MISC::GET_HASH_KEY(vehicleInputName.c_str());
                if (STREAMING::IS_MODEL_IN_CDIMAGE(modelHash)) {
                    STREAMING::REQUEST_MODEL(modelHash);
                    while (!STREAMING::HAS_MODEL_LOADED(modelHash)) { scriptWait(0); }
                    
                    Ped playerPed = PLAYER::PLAYER_PED_ID();
                    Vector3 coords = ENTITY::GET_OFFSET_FROM_ENTITY_IN_WORLD_COORDS(playerPed, 0.0f, 5.0f, 0.0f);
                    float heading = ENTITY::GET_ENTITY_HEADING(playerPed);
                    
                    Vehicle veh = VEHICLE::CREATE_VEHICLE(modelHash, coords.x, coords.y, coords.z, heading, true, false, false);
                    PED::SET_PED_INTO_VEHICLE(playerPed, veh, -1);
                    STREAMING::SET_MODEL_AS_NO_LONGER_NEEDED(modelHash);
                }
                vehicleInputName = ""; // Clear string data cleanly
            }
        }
    }

    // ==========================================
    // 4. LIVE IN-GAME EXECUTION SUBROUTINES
    // ==========================================
    Ped playerPed = PLAYER::PLAYER_PED_ID();
    Player player = PLAYER::PLAYER_ID();

    if (godmode) {
        PLAYER::SET_PLAYER_INVINCIBLE(player, true);
        ENTITY::SET_ENTITY_PROOFS(playerPed, true, true, true, true, true, true, true, true);
    } else {
        PLAYER::SET_PLAYER_INVINCIBLE(player, false);
    }

    if (moneyDrop) {
        Vector3 coords = ENTITY::GET_ENTITY_COORDS(playerPed, true);
        OBJECT::CREATE_AMBIENT_PICKUP(MISC::GET_HASH_KEY("PICKUP_MONEY_CASE"), coords.x, coords.y, coords.z + 0.5f, 0, 25000, 0, false, true);
    }

    if (noMissionFailure) {
        MISC::SET_MISSION_FLAG(true);
        PLAYER::SET_DISABLE_AUTOMATIC_RESPAWN(true);
    }

    if (infAmmo) {
        WEAPON::SET_PED_INFINITE_AMMO_CLIP(playerPed, true);
    } else {
        WEAPON::SET_PED_INFINITE_AMMO_CLIP(playerPed, false);
    }

    if (noReload) {
        Hash currentWeapon;
        if (WEAPON::GET_CURRENT_PED_WEAPON(playerPed, &currentWeapon, true)) {
            int maxClip = WEAPON::GET_MAX_AMMO_IN_CLIP(playerPed, currentWeapon, true);
            WEAPON::SET_AMMO_IN_CLIP(playerPed, currentWeapon, maxClip);
        }
    }

    if (tenfoldBullets && PED::IS_PED_SHOOTING(playerPed)) {
        PLAYER::SET_PLAYER_WEAPON_DAMAGE_MODIFIER(player, 10.0f);
    } else if (hundredfoldBullets && PED::IS_PED_SHOOTING(playerPed)) {
        PLAYER::SET_PLAYER_WEAPON_DAMAGE_MODIFIER(player, 100.0f);
    } else if (!tenfoldBullets && !hundredfoldBullets) {
        PLAYER::SET_PLAYER_WEAPON_DAMAGE_MODIFIER(player, 1.0f);
    }

    Hash weaponHash;
    if (WEAPON::GET_CURRENT_PED_WEAPON(playerPed, &weaponHash, true)) {
        if (ultimateSpeedShoot) {
            PLAYER::SET_TIME_SCALE(0.4f); 
        } else if (speedyRpg && (weaponHash == MISC::GET_HASH_KEY("WEAPON_RPG") || weaponHash == MISC::GET_HASH_KEY("WEAPON_HOMINGLAUNCHER"))) {
            WEAPON::REFILL_AMMO_INSTANTLY(playerPed);
        } else {
            PLAYER::SET_TIME_SCALE(1.0f); 
        }
    }
}
