#include "menu.h"

namespace NativeMenu {
    void Menu::Title(const char* title) {
        maxOptions = 0;
        optionPressed = false;
        leftPressed = false;
        rightPressed = false;
        HandleControls();

        // Banner Graphic Rendering
        GRAPHICS::DRAW_RECT(0.15f, 0.12f, 0.22f, 0.08f, hR, hG, hB, hA, false);
        HUD::BEGIN_TEXT_COMMAND_DISPLAY_TEXT("STRING");
        HUD::ADD_TEXT_COMPONENT_SUBSTRING_PLAYER_NAME(title);
        HUD::SET_TEXT_FONT(1);
        HUD::SET_TEXT_SCALE(0.0f, 0.7f);
        HUD::SET_TEXT_COLOUR(txR, txG, txB, txA);
        HUD::SET_TEXT_CENTRE(true);
        HUD::END_TEXT_COMMAND_DISPLAY_TEXT(0.15f, 0.10f, 0);
    }

    bool Menu::MenuOption(const char* option, const char* targetMenu) {
        maxOptions++;
        float yPos = 0.16f + (maxOptions * 0.04f);
        bool isHighlighted = (currentOption == maxOptions - 1);

        // Draw selection highlight block background
        if (isHighlighted) {
            GRAPHICS::DRAW_RECT(0.15f, yPos + 0.015f, 0.22f, 0.04f, hiR, hiG, hiB, hiA, false);
        } else {
            GRAPHICS::DRAW_RECT(0.15f, yPos + 0.015f, 0.22f, 0.04f, bgR, bgG, bgB, bgA, false);
        }

        HUD::BEGIN_TEXT_COMMAND_DISPLAY_TEXT("STRING");
        HUD::ADD_TEXT_COMPONENT_SUBSTRING_PLAYER_NAME(option);
        HUD::SET_TEXT_FONT(0);
        HUD::SET_TEXT_SCALE(0.0f, 0.35f);
        HUD::SET_TEXT_COLOUR(txR, txG, txB, txA);
        HUD::END_TEXT_COMMAND_DISPLAY_TEXT(0.05f, yPos, 0);

        if (isHighlighted && optionPressed) {
            currentMenu = targetMenu;
            currentOption = 0;
            return true;
        }
        return false;
    }

    bool Menu::Button(const char* option) {
        maxOptions++;
        float yPos = 0.16f + (maxOptions * 0.04f);
        bool isHighlighted = (currentOption == maxOptions - 1);

        if (isHighlighted) {
            GRAPHICS::DRAW_RECT(0.15f, yPos + 0.015f, 0.22f, 0.04f, hiR, hiG, hiB, hiA, false);
        } else {
            GRAPHICS::DRAW_RECT(0.15f, yPos + 0.015f, 0.22f, 0.04f, bgR, bgG, bgB, bgA, false);
        }

        // Draw Standard Selection Button Option Text
        HUD::BEGIN_TEXT_COMMAND_DISPLAY_TEXT("STRING");
        HUD::ADD_TEXT_COMPONENT_SUBSTRING_PLAYER_NAME(option);
        HUD::SET_TEXT_FONT(0);
        HUD::SET_TEXT_SCALE(0.0f, 0.35f);
        HUD::SET_TEXT_COLOUR(txR, txG, txB, txA);
        HUD::END_TEXT_COMMAND_DISPLAY_TEXT(0.05f, yPos, 0);

        return (isHighlighted && optionPressed);
    }

    bool Menu::BoolOption(const char* option, bool* toggle) {
        bool pressed = Button(option);
        float yPos = 0.16f + (maxOptions * 0.04f);

        if (*toggle) {
            DrawMenuText("[ON]", 0, 0.23f, yPos, 0.0f, 0.35f, 0, 255, 0, 255, false);
        } else {
            DrawMenuText("[OFF]", 0, 0.23f, yPos, 0.0f, 0.35f, 255, 0, 0, 255, false);
        }

        if (pressed) {
            *toggle = !(*toggle);
            return true;
        }
        return false;
    }

    void Menu::HandleControls() {
        // Simple built-in keyboard navigation tracking map (Numpad 8, 2, 5)
        if (PAD::IS_DISABLED_CONTROL_JUST_PRESSED(2, 172)) { // Numpad 8 Up
            currentOption = (currentOption > 0) ? currentOption - 1 : maxOptions - 1;
        }
        if (PAD::IS_DISABLED_CONTROL_JUST_PRESSED(2, 173)) { // Numpad 2 Down
            currentOption = (currentOption < maxOptions - 1) ? currentOption + 1 : 0;
        }
        if (PAD::IS_DISABLED_CONTROL_JUST_PRESSED(2, 176)) { // Numpad 5 Select
            optionPressed = true;
        }
    }
}
